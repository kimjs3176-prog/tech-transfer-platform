# ── Vercel Postgres (자동 주입) ──────────────────────────────────
POSTGRES_URL=postgresql://...

# ── Vercel KV / Upstash Redis (자동 주입) ──────────────────────
KV_URL=redis://...

# ── Vercel Blob (자동 주입) ─────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ── 앱 설정 ─────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
FRONTEND_URL=https://your-app.vercel.app

# ── 특허청 KIPRIS API ───────────────────────────────────────────
KIPRIS_API_KEY=your-kipris-api-key

# ── 로컬 개발 전용 (Vercel 배포 시 불필요) ──────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tech_transfer
# REDIS_URL=redis://localhost:6379/0
